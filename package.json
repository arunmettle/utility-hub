{
  "name": "utility-hub",
  "private": true,
  "version": "1.0.0",
  "description": "Privacy-first browser utilities for developers, reviewers, and platform teams",
  "type": "module",
  "author": "UtilityHub",
  "license": "MIT",
  "keywords": [
    "utilities",
    "developer-tools",
    "json-formatter",
    "base64",
    "hash-generator",
    "qr-code",
    "password-generator",
    "jwt-decoder",
    "openapi",
    "diff-tools",
    "docker-compose",
    "privacy-first",
    "client-side"
  ],
  "scripts": {
    "dev": "vite",
    "prepare:adsense": "node scripts/prepare-adsense.mjs",
    "build": "npm run prepare:adsense && tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run --coverage",
    "test:unit": "vitest run --coverage",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:report": "node scripts/generate-playwright-validation-report.mjs",
    "test:e2e:validate": "node scripts/run-playwright-validation.mjs"
  },
  "dependencies": {
    "@breezystack/lamejs": "^1.2.7",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.4.0",
    "js-md5": "^0.8.3",
    "js-sha256": "^0.11.1",
    "js-sha512": "^0.9.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.20.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.18.0",
    "xlsx": "^0.18.5",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/crypto-js": "^4.2.2",
    "@types/js-md5": "^0.8.0",
    "@types/node": "^24.12.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.9"
  }
}
