# Optional AdSense monetization
VITE_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
VITE_ADSENSE_TOP_SLOT=1234567890
VITE_ADSENSE_FLOAT_SLOT=0987654321
VITE_ADSENSE_ADS_TXT_LINE=google.com, pub-xxxxxxxxxxxxxxxx, DIRECT, f08c47fec0942fa0

# Optional: override same-origin Cloudflare Pages Functions submission endpoints.
# Defaults are /api/feedback and /api/wishlist.
VITE_FEEDBACK_ENDPOINT=/api/feedback
VITE_WISHLIST_ENDPOINT=/api/wishlist

# Optional public Turnstile site key for spam protection on public forms
# and Planning Poker room creation. Set the matching secret in Cloudflare
# as TURNSTILE_SECRET_KEY.
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
